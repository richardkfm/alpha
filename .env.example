# alpha — docker compose overrides. Copy to .env and edit as needed:
#
#   cp .env.example .env
#
# docker compose reads .env from this directory automatically. Change any port
# that collides with something already running on your machine. Only the HOST
# side of each mapping changes — container-internal ports and the
# service-to-service URLs (db:5432, backend:8000) are unaffected, so no other
# file needs editing.

# Web app (open this in your browser) -> http://localhost:${ALPHA_WEB_PORT}
ALPHA_WEB_PORT=3000

# Backend API + Swagger docs           -> http://localhost:${ALPHA_API_PORT}
ALPHA_API_PORT=8000

# PostgreSQL / PostGIS (host access only; the backend reaches it as db:5432)
ALPHA_DB_PORT=5432

# Hostnames allowed to reach the web app when it's served behind a reverse proxy
# or tunnel (Cloudflare Tunnel, Nginx, …). Vite blocks unknown Host headers, so
# set this to the domain(s) you serve on — comma-separated, or "all" to allow any
# host. Leave empty for localhost-only access.
#   ALPHA_ALLOWED_HOSTS=alpha.example.com,alpha.internal.lan
ALPHA_ALLOWED_HOSTS=
