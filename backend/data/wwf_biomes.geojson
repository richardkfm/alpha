{
  "type": "FeatureCollection",
  "name": "alpha_biome_boundaries_seed",
  "description": "Phase 3 seed biome-boundary dataset. Coarse, simplified footprints derived from the WWF Terrestrial Ecoregions of the World (Olson et al. 2001) biome classes, plus blue-carbon (mangrove) and inland-wetland references. These are deliberately low-resolution polygons used to classify a point/polygon into one of alpha's five valuation biomes; they are NOT authoritative boundaries. Refresh from the authoritative source with `python ingest.py refresh` (see backend/INGESTION.md). Each feature maps to a biome_key in reference_data.BIOMES.",
  "source": {
    "primary": "Olson, D.M. et al. (2001). Terrestrial Ecoregions of the World. BioScience 51(11): 933-938. WWF/TEOW.",
    "mangrove": "Giri, C. et al. (2011). Global mangrove forests distribution (USGS/MEoW).",
    "wetland": "Ramsar / ESVD inland-wetland reference sites.",
    "url": "https://www.worldwildlife.org/publications/terrestrial-ecoregions-of-the-world",
    "as_of": "2026-06",
    "note": "Simplified for in-repo point-in-polygon classification."
